{
  "manifest_version": 3,
  "name": "MailArmour - Gmail Phishing Detector",
  "version": "1.0",
  "description": "Real-time AI phishing protection for Gmail. MailArmour instantly detects dangerous emails and keeps your inbox safe.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://mailarmour-extension-production.up.railway.app/*",
    "https://api.domainsdb.info/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "trigger-scan": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Scan the current email"
    }
  }
}

